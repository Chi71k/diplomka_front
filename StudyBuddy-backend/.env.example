# Copy to .env and adjust for local development
# cp .env.example .env

# ---------- Database (must match docker-compose) ----------
POSTGRES_USER=studybuddy
POSTGRES_PASSWORD=studybuddy
POSTGRES_DB=studybuddy
POSTGRES_PORT=5432
DATABASE_URL=postgres://studybuddy:studybuddy@localhost:5432/studybuddy?sslmode=disable

# ---------- Auth service ----------
AUTH_SERVER_PORT=8080
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_ISSUER=studybuddy-auth
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ---------- Users service ----------
USERS_SERVER_PORT=8081

# ---------- API Gateway (when added) ----------
# GATEWAY_PORT=8000
# AUTH_SERVICE_URL=http://auth:8080
# USERS_SERVICE_URL=http://users:8081
